FROM python:3.11-slim

LABEL org.opencontainers.image.title="data-cleaning-openenv"
LABEL org.opencontainers.image.description="OpenEnv environment for tabular data cleaning"
LABEL space_sdk_type="openenv"

WORKDIR /app

#System deps 
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
    && rm -rf /var/lib/apt/lists/*

#Python deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

#Application code
COPY models.py       ./models.py
COPY client.py       ./client.py
COPY server/         ./server/

#Non-root user
RUN useradd -m appuser
USER appuser

EXPOSE 8000

#Entrypoint
CMD ["uvicorn", "server.app:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]